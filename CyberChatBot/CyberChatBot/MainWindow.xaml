<Window x:Class="CyberChatBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CyberChatBot"
        mc:Ignorable="d"
        Title="🛡️CyberChatBot - Cybersecurity Awareness Bot" Height="760" Width="1383"
        Background="#0d1117" Foreground="#e6edf3"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="0,0,0,17">
        <Grid.RowDefinitions>
            <!-- Main content area — fills all available space -->
            <RowDefinition/>
            <!-- Status bar — fixed height at the bottom -->
            <RowDefinition Height="Auto" MinHeight="65.04"/>
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════
             NAME ENTRY PANEL
             Shown on startup, hidden after name entered
        ══════════════════════════════════════════ -->
        <StackPanel x:Name="NamePanel"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Width="600" Height="364">

            <Border Background="#161b22" CornerRadius="12" Padding="36" Width="603">
                <StackPanel>
                    <!-- Bot logo text -->
                    <TextBlock
                               FontSize="35" FontWeight="Bold"
                               Foreground="#58a6ff"
                               TextAlignment="Center"
                               Margin="0,0,0,6" Height="48">
                        
                     <Run Text="🛡️CyberChatBot"/>
                    </TextBlock>

                    <TextBlock Text="Cybersecurity Awareness Bot"
                               FontSize="25"
                               Foreground="#58a6ff"
                               TextAlignment="Center"
                               Margin="0,0,0,4" Height="28"/>

                    <TextBlock Text="Your personal guide to staying safe online"
                               FontSize="20"
                               Foreground="White"
                               TextAlignment="Center"
                               Margin="0,0,0,28"/>

                    <!-- Divider -->
                    <Border BorderBrush="#30363d" BorderThickness="0,1,0,0" Margin="0,0,0,24"/>

                    <TextBlock Text="What's your name?"
                               FontSize="24"
                               Foreground="#c9d1d9"
                               Margin="0,0,0,8"/>

                    <!-- Name text box -->
                    <TextBox x:Name="NameInput"
                             Height="56"
                             Padding="12,10"
                             FontSize="20"
                             Background="#0d1117"
                             Foreground="#e6edf3"
                             CaretBrush="White"
                             BorderBrush="#30363d"
                             BorderThickness="1"
                             KeyDown="NameInput_KeyDown"
                             Margin="0,0,0,8"/>

                    <!-- Validation error message -->
                    <TextBlock x:Name="NameError"
                               Text="Please enter your name to continue."
                               Foreground="#f85149"
                               FontSize="12"
                               Visibility="Collapsed"
                               Margin="0,0,0,10"/>

                    <!-- Start Chat button -->
                    <Button x:Name="StartChatBtn"
                            Content="Start Chat"
                            Click="StartChat_Click"
                            Height="61"
                            Background="#238636"
                            Foreground="White"
                            FontSize="25"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            BorderThickness="0"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- ══════════════════════════════════════════
             CHAT PANEL
             Hidden until name is entered
        ══════════════════════════════════════════ -->
        <Grid x:Name="ChatContainer"
              Grid.Row="0"
              Visibility="Collapsed">

            <Grid.RowDefinitions>
                <!-- Header bar -->
                <RowDefinition Height="Auto"/>
                <!-- Scrollable chat messages -->
                <RowDefinition Height="*"/>
                <!-- Message input area -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header Bar -->
            <Border Grid.Row="0"
                    Background="#161b22"
                    Padding="16,12"
                    BorderBrush="#30363d"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Bot title and subtitle -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="🛡"
                                   FontSize="40"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="CYBERSECURITY AWARENESS BOT"
                                       Foreground="#58a6ff"
                                       FontSize="45"
                                       FontWeight="Bold"/>
                            <TextBlock Text="Your guide to staying safe online"
                                       Foreground="#8b949e"
                                       FontSize="25"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Secure session indicator -->
                    <TextBlock Grid.Column="1"
                               Text="Secure Session"
                               Foreground="#3fb950"
                               FontSize="20"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Chat Messages ScrollViewer -->
            <ScrollViewer x:Name="ChatScrollViewer"
                          Grid.Row="1"
                          Background="#0d1117"
                          VerticalScrollBarVisibility="Auto"
                          Padding="15,10">
                <StackPanel x:Name="ChatPanel" Orientation="Vertical"/>
            </ScrollViewer>

            <!-- Message Input Area -->
            <Border x:Name="InputArea"
                    Grid.Row="2"
                    Background="#161b22"
                    BorderBrush="#30363d"
                    BorderThickness="0,1,0,0"
                    Padding="15,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <!-- Message text box -->
                        <ColumnDefinition Width="*"/>
                        <!-- Quiz button -->
                        <ColumnDefinition Width="Auto"/>
                        <!-- Tasks button -->
                        <ColumnDefinition Width="Auto"/>
                        <!-- Send button -->
                        <ColumnDefinition Width="Auto"/>
                        <!-- Clear button -->
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="UserInput"
                             Grid.Column="0"
                             Height="45"
                             Padding="12,10"
                             FontSize="13"
                             Background="#0d1117"
                             Foreground="#e6edf3"
                             CaretBrush="White"
                             BorderBrush="#30363d"
                             BorderThickness="1"
                             KeyDown="UserInput_KeyDown"
                             Margin="0,0,10,0"/>

                    <Button x:Name="QuizButton"
                            Grid.Column="1"
                            Content="🎮 Quiz"
                            Click="QuizButton_Click"
                            Width="90" Height="45"
                            Background="#9e6a03"
                            Foreground="White"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            BorderThickness="0"
                            Margin="0,0,8,0"/>

                    <Button x:Name="TasksButton"
                            Grid.Column="2"
                            Content="📋 Tasks"
                            Click="TasksButton_Click"
                            Width="90" Height="45"
                            Background="#1f6feb"
                            Foreground="White"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            BorderThickness="0"
                            Margin="0,0,8,0"/>

                    <Button x:Name="SendButton"
                            Grid.Column="3"
                            Content="Send ➤"
                            Click="SendButton_Click"
                            Width="85" Height="45"
                            Background="#238636"
                            Foreground="White"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            BorderThickness="0"
                            Margin="0,0,8,0"/>

                    <Button x:Name="ClearButton"
                            Grid.Column="4"
                            Content="Clear Chat"
                            Click="ClearChat_Click"
                            Width="100" Height="45"
                            Background="#21262d"
                            Foreground="#8b949e"
                            BorderBrush="#30363d"
                            BorderThickness="1"
                            Cursor="Hand"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ══════════════════════════════════════════
             QUIZ POPUP PANEL
             Hidden until the user starts the mini-game
        ══════════════════════════════════════════ -->
        <Grid x:Name="QuizOverlay"
              Grid.Row="0"
              Background="#B30d1117"
              Visibility="Collapsed">

            <Border Background="#161b22"
                    CornerRadius="14"
                    Padding="32"
                    Width="700"
                    MaxHeight="560"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    BorderBrush="#30363d"
                    BorderThickness="1">
                <StackPanel>
                    <!-- Header -->
                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="🎮 Cybersecurity Quiz"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Foreground="#58a6ff"/>
                        <TextBlock x:Name="QuizProgressText"
                                   Grid.Column="1"
                                   Text="Question 1/12"
                                   FontSize="18"
                                   Foreground="#8b949e"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Question text -->
                    <Border Background="#0d1117"
                            CornerRadius="8"
                            Padding="20,16"
                            Margin="0,0,0,18">
                        <TextBlock x:Name="QuizQuestionText"
                                   Text="Question goes here"
                                   FontSize="19"
                                   Foreground="#e6edf3"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <!-- Answer options -->
                    <StackPanel x:Name="QuizOptionsPanel" Margin="0,0,0,12"/>

                    <!-- Feedback message -->
                    <TextBlock x:Name="QuizFeedbackText"
                               Text=""
                               FontSize="16"
                               TextWrapping="Wrap"
                               Foreground="#3fb950"
                               Margin="0,0,0,14"
                               Visibility="Collapsed"/>

                    <!-- Footer buttons -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   x:Name="QuizScoreText"
                                   Text="Score: 0"
                                   FontSize="16"
                                   Foreground="#8b949e"
                                   VerticalAlignment="Center"/>

                        <Button x:Name="QuizNextButton"
                                Grid.Column="1"
                                Content="Next ➤"
                                Click="QuizNextButton_Click"
                                Width="120" Height="42"
                                Background="#238636"
                                Foreground="White"
                                FontWeight="SemiBold"
                                Cursor="Hand"
                                BorderThickness="0"
                                Margin="0,0,10,0"
                                Visibility="Collapsed"/>

                        <Button x:Name="QuizCloseButton"
                                Grid.Column="2"
                                Content="Close"
                                Click="QuizCloseButton_Click"
                                Width="100" Height="42"
                                Background="#21262d"
                                Foreground="#8b949e"
                                BorderBrush="#30363d"
                                BorderThickness="1"
                                Cursor="Hand"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ══════════════════════════════════════════
             TASKS POPUP PANEL
             Hidden until the user opens the task list
        ══════════════════════════════════════════ -->
        <Grid x:Name="TasksOverlay"
              Grid.Row="0"
              Background="#B30d1117"
              Visibility="Collapsed">

            <Border Background="#161b22"
                    CornerRadius="14"
                    Padding="28"
                    Width="640"
                    MaxHeight="560"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    BorderBrush="#30363d"
                    BorderThickness="1">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="📋 Your Cybersecurity Tasks"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#58a6ff"/>
                        <Button x:Name="TasksCloseButton"
                                Grid.Column="1"
                                Content="Close"
                                Click="TasksCloseButton_Click"
                                Width="90" Height="38"
                                Background="#21262d"
                                Foreground="#8b949e"
                                BorderBrush="#30363d"
                                BorderThickness="1"
                                Cursor="Hand"/>
                    </Grid>

                    <ScrollViewer MaxHeight="400" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="TasksListPanel"/>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ══════════════════════════════════════════
             STATUS BAR
             Always visible at the bottom of the window
        ══════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Background="#161b22"
                BorderBrush="#30363d"
                BorderThickness="0,1,0,0"
                Padding="15,7" Margin="0,33,0,-59">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto" MinWidth="2"/>
                </Grid.ColumnDefinitions>

                <!-- Dynamic status message -->
                <TextBlock x:Name="StatusText"
                           Grid.Column="0"
                           Text="Enter your name to begin"
                           Foreground="#8b949e"
                           FontSize="24" Grid.ColumnSpan="2" Margin="-8,0,-7,0"/>

                <!-- Memory indicator -->
                <TextBlock
                           Text="🧠 Memory: Active"
                           Foreground="#3fb950"
                           FontSize="24" Margin="1090,0,-7,0" Grid.ColumnSpan="2"/>
            </Grid>
        </Border>
    </Grid>
</Window>
